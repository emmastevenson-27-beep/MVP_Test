# Copy this file to .env.local and fill in real values for local development.
# In Vercel, add the same names under Project Settings -> Environment Variables.
# Never commit .env.local — it's already in .gitignore.

# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud service account (Sheets API access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# Optional: protects /api/cron/sheet-sync from being called by anyone who
# finds the URL. Not in the spec's required env var list — leave unset to
# skip the check entirely (Vercel Cron will still trigger the route fine).
CRON_SECRET=
